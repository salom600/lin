{
    // =========================================================================
    // Lin OS βÄî waybar (top panel, Windows 11-style)
    // =========================================================================
    // Layout:
    //   [apps-launcher] [workspaces] ........ [clock] ........ [tray] [battery]
    //
    // "Modern, sleek, transparent" βÄî matches the brief.
    // =========================================================================

    "layer": "top",
    "position": "bottom",
    "height": 44,
    "spacing": 4,
    "margin-top": 0,
    "margin-bottom": 0,
    "margin-horizontal": 0,
    "fixed-center": true,

    // Modules used (left/center/right)
    "modules-left": [
        "custom/launcher",      // "Start" button (Windows flag equivalent)
        "hyprland/workspaces",  // virtual desktops (numbered dots)
        "hyprland/window"       // current window title (small, centered)
    ],

    "modules-center": [
        "clock"                 // big clock in the center (Windows 11-like)
    ],

    "modules-right": [
        "pulseaudio",
        "backlight",
        "bluetooth",
        "network",
        "battery",
        "custom/updates",
        "tray",
        "custom/power"
    ],

    // =========================================================================
    // "Start" button βÄî opens wofi app launcher
    // =========================================================================
    "custom/launcher": {
        "format": " βù• ",   // Lin OS logo glyph
        "tooltip": true,
        "tooltip-format": "Lin OS βÄî click to open app launcher (Super+D)",
        "on-click": "wofi --show drun --prompt 'Search apps...'",
        "on-click-right": "wlogout"
    },

    // =========================================================================
    // Workspaces βÄî Windows 11-like virtual desktop indicator
    // =========================================================================
    "hyprland/workspaces": {
        "disable-scroll": false,
        "all-outputs": true,
        "format": "{icon}",
        "format-icons": {
            "1": "βÖ†",
            "2": "βÖΓ",
            "3": "βÖΔ",
            "4": "βÖΘ",
            "5": "βÖΛ",
            "6": "βÖΞ",
            "7": "βÖΠ",
            "8": "βÖß",
            "9": "βÖ®",
            "10": "βÖ©",
            "default": "¬Ζ",
            "urgent": "!"
        },
        "persistent-workspaces": {
            "1": [],
            "2": [],
            "3": [],
            "4": []
        }
    },

    // =========================================================================
    // Current window title
    // =========================================================================
    "hyprland/window": {
        "format": "{}",
        "max-length": 50,
        "rewrite": {
            "(.*) βÄî Mozilla Firefox": "πü¨ê  $1",
            "(.*) βÄî Visual Studio Code": "πü£Μ  $1",
            "(.*) βÄî Files": "πü™¹  $1",
            "(.*) βÄî kitty": ">_  $1"
        }
    },

    // =========================================================================
    // Clock βÄî center, with date
    // =========================================================================
    "clock": {
        "format": "  {:%H:%M}  ",
        "format-alt": "  {:%A, %B %d, %Y βÄî %H:%M}  ",
        "tooltip-format": "<tt>{calendar}</tt>",
        "calendar": {
            "mode": "year",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months":     "<span color='#ffead3'><b>{}</b></span>",
                "days":       "<span color='#ecc6d9'><b>{}</b></span>",
                "weeks":      "<span color='#99ffdd'><b>W{}</b></span>",
                "weekdays":   "<span color='#ffcc66'><b>{}</b></span>",
                "today":      "<span color='#ff6699'><b><u>{}</u></b></span>"
            }
        },
        "actions": {
            "on-click-right": "mode",
            "on-click-forward": "tz_up",
            "on-click-backward": "tz_down",
            "on-scroll-up": "shift_up",
            "on-scroll-down": "shift_down"
        }
    },

    // =========================================================================
    // Audio
    // =========================================================================
    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-bluetooth": "{icon} {volume}% σΑ²·",
        "format-bluetooth-muted": "σΑΗà {icon} σΑ²·",
        "format-muted": "σΑΗà muted",
        "format-source": "{volume}% σΑç§",
        "format-source-muted": "σΑç≠ muted",
        "format-icons": {
            "headphone": "σΑ΄΄",
            "hands-free": "σΑ΄é",
            "headset": "σΑ΄é",
            "phone": "σΑ³û",
            "portable": "σΑ³û",
            "car": "σΑ³ç",
            "default": ["σΑïΩ", "σΑ•Ä", "σΑïΨ"]
        },
        "scroll-step": 1,
        "on-click": "pavucontrol",
        "on-click-right": "pactl set-sink-mute @DEFAULT_SINK@ toggle"
    },

    "backlight": {
        "format": "{icon} {percent}%",
        "format-icons": ["σΑÉû", "σΑÉü", "σΑÉ†"],
        "on-scroll-up":   "brightnessctl set +5%",
        "on-scroll-down": "brightnessctl set 5%-"
    },

    // =========================================================================
    // Bluetooth
    // =========================================================================
    "bluetooth": {
        "format": "σΑ²·",
        "format-connected": "σΑ²± {num_connections}",
        "tooltip-format": "{controller_alias}\t{controller_address}",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "on-click": "blueman-manager"
    },

    // =========================================================================
    // Network
    // =========================================================================
    "network": {
        "format-wifi": "σΑΛ® {essid}",
        "format-ethernet": "σΑàÄ {ipaddr}",
        "format-linked": "σΑàÄ {ifname} (No IP)",
        "format-disconnected": "σΑΛ≠ disconnected",
        "format-alt": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-format-wifi": "{essid} ({signalStrength}%) βÄî {frequency} GHz\n{ipaddr}",
        "on-click": "nm-connection-editor"
    },

    // =========================================================================
    // Battery
    // =========================================================================
    "battery": {
        "states": {
            "good": 95,
            "warning": 30,
            "critical": 15
        },
        "format": "{icon} {capacity}%",
        "format-charging": "σΑ²³ {capacity}%",
        "format-plugged": "σΑöΞ {capacity}%",
        "format-alt": "{icon} {time}",
        "format-icons": ["σΑ¹Κ", "σΑ¹Μ", "σΑ¹Φ", "σΑ¹Ϋ", "σΑ¹Ψ", "σΑ¹Ω", "σΑ²Ä", "σΑ²¹", "σΑ²²", "σΑ¹Ι"]
    },

    // =========================================================================
    // Updates indicator (counts pending pacman updates)
    // =========================================================================
    "custom/updates": {
        "format": "σΑöΑ {}",
        "tooltip": true,
        "tooltip-format": "Pending updates: {}",
        "exec": "checkupdates | wc -l",
        "interval": 3600,
        "on-click": "lin-update",
        "exec-if": "exit 0"
    },

    // =========================================================================
    // System tray
    // =========================================================================
    "tray": {
        "icon-size": 18,
        "spacing": 8,
        "show-passive-items": true
    },

    // =========================================================================
    // Power button (right edge)
    // =========================================================================
    "custom/power": {
        "format": "βèΜ",
        "tooltip": true,
        "tooltip-format": "Power menu",
        "on-click": "wlogout -b 4"
    }
}
