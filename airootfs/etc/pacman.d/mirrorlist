#
# /etc/pacman.d/mirrorlist — Lin OS
#
# This is a minimal fallback mirrorlist used during the ISO build.
# On first boot, /etc/lin/firstboot.sh runs `reflector` to fetch the
# fastest mirrors for the user's location and overwrites this file.
#

Server = https://geo.mirror.pkgbuild.com/$repo/os/$arch
Server = https://mirror.rackspace.com/archlinux/$repo/os/$arch
Server = https://mirrors.kernel.org/archlinux/$repo/os/$arch
Server = https://mirrors.ocf.berkeley.edu/archlinux/$repo/os/$arch
Server = https://mirror.arizona.edu/archlinux/$repo/os/$arch
