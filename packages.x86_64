# =============================================================================
# Lin OS — package list (x86_64)
# =============================================================================
# Every package listed here is installed into the live ISO's airootfs.
# The same set is what gets laid onto the user's disk by Calamares' unpackfs
# module (see airootfs/etc/calamares/modules/unpackfs.conf), so what's on
# the live ISO IS what's installed — no separate install stage needed.
#
# Design constraints:
#   - Idle RAM ~150 MB with full desktop running
#   - Modern Wayland stack with native transparency/blur (Hyprland)
#   - One-click install (Calamares), app store (Bauh), Windows-11-style UX
#   - Gaming-ready (glibc, mesa, vulkan, steam dependencies via Flatpak)
# =============================================================================

# ---- Base system ------------------------------------------------------------
base
base-devel
linux
linux-firmware
mkinitcpio
mkinitcpio-archiso
systemd
systemd-sysvcompat
dbus-broker
filesystem
fsarchiver
haveged
intel-ucode
amd-ucode
openssh
openresolv
procps-ng
reflector
sudo
vim
which
zsh

# ---- Network ----------------------------------------------------------------
networkmanager
modemmanager
network-manager-applet
iwd
bluez
bluez-utils
usb_modeswitch

# ---- Audio (PipeWire — the modern, low-latency stack) -----------------------
pipewire
pipewire-pulse
pipewire-alsa
pipewire-jack
pipewire-audio
wireplumber
pavucontrol

# ---- Video / GPU ------------------------------------------------------------
mesa
vulkan-radeon
vulkan-intel
vulkan-nouveau
vulkan-swrast
vulkan-mesa-layers
lib32-mesa
lib32-vulkan-radeon
lib32-vulkan-intel
lib32-vulkan-mesa-layers
intel-media-driver
libva
libva-utils
libva-intel-driver

# ---- Hyprland desktop stack -------------------------------------------------
# Hyprland is a Wayland compositor with built-in blur, rounded corners,
# animations and transparency — exactly the "modern, sleek, transparent"
# look the brief asks for, and it idles at ~250-350 MB with the full stack.
# NOTE: Hyprland 0.40+ ships its own wlroots fork, so 'wlroots' is NOT needed
# (and was removed from the repos anyway).
hyprland
hyprcursor
hypridle
hyprlang
hyprlock
hyprpaper
hyprutils
xdg-desktop-portal-hyprland
qt5-wayland
qt6-wayland
xorg-xwayland
wayland
wayland-protocols
wayland-utils
polkit-kde-agent
qt6ct
qt5ct

# ---- Panel, launcher, notifications -----------------------------------------
waybar
wofi
dunst
swaybg
swaylock
slurp
grim
wl-clipboard
cliphist
polkit

# ---- File manager, terminal, editor -----------------------------------------
thunar
thunar-volman
thunar-archive-plugin
file-roller
kitty
micro
gedit

# ---- GTK / Qt theming -------------------------------------------------------
# NOTE: gtk-engines and gtk-engine-murrine are old GTK2 theming engines that
# were removed from the official repos (now AUR-only). Modern GTK3/4 themes
# don't need them. kvantum-vertex is also AUR-only; 'kvantum' provides the
# engine itself.
gtk3
gtk4
gnome-themes-extra
qt5-base
qt6-base
kvantum

# ---- Icon themes (Windows 11-like) ------------------------------------------
papirus-icon-theme
adwaita-icon-theme
hicolor-icon-theme

# ---- Fonts ------------------------------------------------------------------
# NOTE: noto-fonts-compat was merged into noto-fonts years ago.
ttf-dejavu
ttf-liberation
noto-fonts
noto-fonts-cjk
noto-fonts-emoji
ttf-roboto
ttf-roboto-mono
ttf-fira-sans
ttf-fira-mono
ttf-jetbrains-mono
gnu-free-fonts
inter-font

# ---- Web browser ------------------------------------------------------------
firefox
firefox-i18n-en-us

# ---- App store + package managers -------------------------------------------
# bauh handles pacman + AUR + Flatpak + AppImage — that's enough for the app
# store. pamac-aur was removed from this list because it's been flaky in
# chaotic-aur (licensing issues with AppStream data); bauh covers the same
# ground.
bauh
flatpak
archlinux-appstream-data
appstream
appstream-qt

# ---- Installer (one-click install to disk) ----------------------------------
# (Calamares branding is shipped via the airootfs overlay at
#  airootfs/etc/calamares/branding/lin/ — not as a separate package.)
calamares
dosfstools
mtools
gparted
parted

