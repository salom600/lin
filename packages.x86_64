mtools

# ---- Lin OS custom packages (built in this repo) ----------------------------
# These are installed from the local repo overlay during build:
#   lin-branding  -> GTK theme + icons + wallpaper + SDDM theme
#   lin-welcome   -> first-boot welcome app
#   lin-defaults  -> /etc/skel defaults
lin-branding
lin-welcome
lin-defaults
